      "id": "a6a49c9f-3d5a-421d-b944-2543d351833f",
      "name": "Buscar Clima",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -432,
        208
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const weather = $input.first().json;\nconst queue = $('Extrair Cidade').first().json.queue;\nconst chatId = $('Extrair Cidade').first().json.chatId;\n\nconst temp = Math.round(weather.main.temp);\nconst sensacao = Math.round(weather.main.feels_like);\nconst tempMin = Math.round(weather.main.temp_min);\nconst tempMax = Math.round(weather.main.temp_max);\nconst umidade = weather.main.humidity;\nconst descricao = weather.weather[0].description;\nconst vento = (weather.wind.speed * 3.6).toFixed(1);\nconst nomeCidade = weather.name;\n\nconst emoji = temp >= 30 ? '🔥' : temp >= 25 ? '☀️' : temp >= 18 ? '🌤️' : temp >= 10 ? '🌥️' : '🥶';\n\nconst mensagem =\n  `${emoji} *Clima em ${nomeCidade}*\\n\\n` +\n  `🌡️ Temperatura: *${temp}°C*\\n` +\n  `🤔 Sensação térmica: ${sensacao}°C\\n` +\n  `⬇️ Mínima: ${tempMin}°C  |  ⬆️ Máxima: ${tempMax}°C\\n` +\n  `💧 Umidade: ${umidade}%\\n` +\n  `💨 Vento: ${vento} km/h\\n` +\n  `📋 Condição: ${descricao}\\n\\n` +\n  `_Dados fornecidos por OpenWeatherMap_`;\n\nreturn [{ json: { chatId, mensagem } }];"
      },
      "id": "ddba90c9-82ec-4a72-84e7-bde4eb566ed0",
      "name": "Formatar Resposta",
