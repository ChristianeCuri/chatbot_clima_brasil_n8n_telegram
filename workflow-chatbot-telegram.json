    {
      "parameters": {
        "jsCode": "const chatId = $('Extrair Cidade').first().json.chatId;\nconst queue = $('Extrair Cidade').first().json.queue;\n\nconst mensagem = `👋 Olá! Eu sou o bot de informações sobre o clima!\n❌ A Cidade que você enviou não foi encontrada.\n📍 Para consultar o clima, envie o nome da cidade (ex.: São Paulo).`;\n\nreturn [{ json: { chatId, mensagem } }];"
      },
