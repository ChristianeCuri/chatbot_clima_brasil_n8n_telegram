      "webhookId": "clima-bot-webhook-001",
      "credentials": {
        "telegramApi": {
          "id": "CREDENCIAL_TELEGRAM",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const message = $input.first().json.message;\nconst text = message?.text || '';\nconst chatId = message?.chat?.id;\nconst firstName = message?.chat?.first_name || 'usuário';\n\n// Verifica se a mensagem começa com um comando\nconst temComando = /^\\/?(?:tempo|clima|weather)/i.test(text);\n\n// Extrai a cidade removendo o comando\nconst cidadeBruta = text\n  .replace(/^\\/?(?:tempo|clima|weather)\\s*/i, '')\n  .trim();\n\n// Só considera cidade se vier com comando\nconst cidade = temComando && cidadeBruta ? cidadeBruta : null;\n\nreturn [{\n  json: {\n    chatId,\n    firstName,\n    cidade: cidade || null,\n    cidadeQuery: cidade ? `${cidade},BR` : null,\n    textoOriginal: text\n  }\n}];"
      },
      "id": "bfea0baa-a8ea-4b9d-a782-c858c72433d5",
      "name": "Extrair Cidade",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        112
      ]
    },
    {
      "parameters": {
