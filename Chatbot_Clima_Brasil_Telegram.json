    {
      "parameters": {
        "jsCode": "const chatId = $('Extrair Cidade').first().json.chatId;\nconst firstName = $('Extrair Cidade').first().json.firstName;\n\nconst mensagem =\n  `👋 Olá, ${firstName}! Eu sou o bot de clima do Brasil!\\n\\n` +\n  `Para consultar a temperatura de uma cidade, envie:\\n\\n` +\n  `📍 /tempo *NomeDaCidade*\\n\\n` +\n  `*Exemplos:*\\n` +\n  `• /tempo São Paulo\\n` +\n  `• /tempo Rio de Janeiro\\n` +\n  `• /tempo Curitiba\\n` +\n  `• /tempo Fortaleza\\n` +\n  `• /tempo Manaus`;\n\nreturn [{ json: { chatId, mensagem } }];"
      },
